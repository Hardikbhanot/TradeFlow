# 🔑 TradeFlow Production Environment Variables
# Copy these to a file named '.env' on your DigitalOcean Droplet in the same folder as docker-compose.deploy.yml

# --- Auth Service ---
AUTH_DB_URL=jdbc:postgresql://your-neon-db-url/authdb?sslmode=require
AUTH_DB_USERNAME=your_username
AUTH_DB_PASSWORD=your_password

# --- User Service ---
USER_DB_URL=jdbc:postgresql://your-neon-db-url/userdb?sslmode=require
USER_DB_USERNAME=your_username
USER_DB_PASSWORD=your_password

# --- Wallet Service ---
WALLET_DB_URL=jdbc:postgresql://your-neon-db-url/walletdb?sslmode=require
WALLET_DB_USERNAME=your_username
WALLET_DB_PASSWORD=your_password

# --- Order Service ---
ORDER_DB_URL=jdbc:postgresql://your-neon-db-url/orderdb?sslmode=require
ORDER_DB_USERNAME=your_username
ORDER_DB_PASSWORD=your_password

# --- Portfolio Service ---
PORTFOLIO_DB_URL=jdbc:postgresql://your-neon-db-url/portfoliodb?sslmode=require
PORTFOLIO_DB_USERNAME=your_username
PORTFOLIO_DB_PASSWORD=your_password

# --- Upstox API (Market Service) ---
UPSTOX_API_KEY=your_api_key
UPSTOX_API_SECRET=your_api_secret
UPSTOX_ACCESS_TOKEN=your_access_token
UPSTOX_REDIRECT_URI=http://api.tradeflow.hbhanot.tech/auth/callback

# --- JWT Security Config ---
# Specify a strong, unique, high-entropy secret key of at least 32 characters (256 bits) for signing tokens.
JWT_SECRET=your_super_secret_high_entropy_key_here

# --- SMTP / Email (Notification Service) ---
SMTP_HOST=smtp.smtp2go.com
SMTP_PORT=2525
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=true
SMTP_FROM=no-reply@hbhanot.tech

# Optional SendGrid fallback (if you want to keep SendGrid available)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@tradeflow.hbhanot.tech
